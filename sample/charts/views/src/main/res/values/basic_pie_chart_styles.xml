<resources>
    <style name="BasicPieChartInsideLabelStyle">
        <item name="pieSliceLabelType">inside</item>
    </style>

    <style name="BasicPieChartWhiteInsideLabelStyle">
        <item name="pieSliceLabelType">inside</item>
        <item name="pieSliceLabelTextStyle">@style/BasicPieChartWhiteLabelTextStyle</item>
    </style>

    <style name="BasicPieChartWhiteLabelTextStyle">
        <item name="android:color">@android:color/white</item>
    </style>

    <style name="BasicPieChartSlice1Style">
        <item name="sliceColor">#3287ff</item>
        <item name="pieSliceLabelStyle">@style/BasicPieChartWhiteInsideLabelStyle</item>
    </style>

    <style name="BasicPieChartSlice2Style">
        <item name="sliceColor">#0ac285</item>
        <item name="pieSliceLabelStyle">@style/BasicPieChartWhiteInsideLabelStyle</item>
    </style>

    <style name="BasicPieChartSlice3Style">
        <item name="sliceColor">#ffab02</item>
        <item name="pieSliceLabelStyle">@style/BasicPieChartInsideLabelStyle</item>
    </style>

    <style name="BasicPieChartStyle">
        <item name="pieSliceStyle1">@style/BasicPieChartSlice1Style</item>
        <item name="pieSliceStyle2">@style/BasicPieChartSlice2Style</item>
        <item name="pieSliceStyle3">@style/BasicPieChartSlice3Style</item>
    </style>
</resources>
