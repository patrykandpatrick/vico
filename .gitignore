#
# DO NOT MODIFY THIS DIRECTLY
# To keep everything consistent, please update
#    $WAHOO_ANDROID_HOME/android_gradle/settings/gitignore.master.txt
# and run
#    find $WAHOO_ANDROID_HOME -mindepth 1 -maxdepth 1 -type d | grep -v 'crux\|comwa\|kotlin_common' | while read f; do cp $WAHOO_ANDROID_HOME/android_gradle/settings/gitignore.master.txt $f/.gitignore; done
# INSPIRED BY https://raw.githubusercontent.com/github/gitignore/master/Android.gitignore
#

# Built application files
**/*.apk
**/*.aar
**/*.ap_
**/*.aab

# Files for the ART/Dalvik VM
**/*.dex

# Java class files
**/*.class

# Generated files
**/bin/
**/gen/
**/out/
#  Uncomment the following line in case you need and you don't have the release build type files in your app
# **/release/

# Gradle files
**/.gradle/
**/build/

# Local configuration file (sdk path, etc)
**/local.properties

# Proguard folder generated by Eclipse
**/proguard/

# Log Files
**/*.log

# Android Studio Navigation editor temp files
**/.navigation/

# Android Studio captures folder
**/captures/

# IntelliJ
**/*.iml
**/.idea/workspace.xml
**/.idea/tasks.xml
**/.idea/gradle.xml
**/.idea/assetWizardSettings.xml
**/.idea/misc.xml
**/.idea/runConfigurations.xml
**/.idea/compiler.xml
**/.idea/dictionaries
**/.idea/libraries
# Android Studio 3 in .gitignore file.
**/.idea/caches
**/.idea/modules.xml
# Comment next line if keeping position of elements in Navigation Editor is relevant for you
**/.idea/navEditor.xml
**/.idea/shelf
**/.idea/deploymentTargetDropDown.xml
**/.idea/deploymentTargetSelector.xml
**/.idea/androidTestResultsUserPreferences.xml
**/.idea/migrations.xml
**/.idea/git_toolbox_blame.xml
**/.idea/vcs.xml
**/.idea/AndroidProjectSystem.xml

# Keystore files
# Uncomment the following lines if you do not want to check your keystore files in.
#**/*.jks
#**/*.keystore

# External native build folder generated in Android Studio 2.2 and later
**/.externalNativeBuild
**/.cxx/

# Freeline
**/freeline.py
**/freeline/
**/freeline_project_description.json

# fastlane
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output
**/fastlane/readme.md

# Version control
**/vcs.xml

# lint
**/lint/intermediates/
**/lint/generated/
**/lint/outputs/
**/lint/tmp/
# **/lint/reports/

#
# Added by Wahoo
#

# MacOS Finder helper files
**/.DS_Store

# Android studio creates these HUGE files when things go wrong
**/*.hprof

# GrepConsole is a great tool. Devs should be allowed to configure it how they want
**/.idea/GrepConsole.xml

# We need this special case AAR to be included for the ApiTestApp
!WahooFitnessAndroidApi.aar

# We need these special cases for the wf_resources repo
**cmake-build*
**/generation.log

/clients/c/Android/CMake_Sources_List.txt

# We do not want to check in these. Devs can pull this by running `yarn install` in the android_gradle directory
node_modules

# We need the special case JAR folder to be included for the AdbTestApp
!test/AdbTestApp/scripts/bin

# BoltLauncher2 has apks is its assets we do not want to ignore
!**/BoltLauncher2/src/main/assets/*

# Generated by Butlr - DO NOT REMOVE THIS.
env.properties
